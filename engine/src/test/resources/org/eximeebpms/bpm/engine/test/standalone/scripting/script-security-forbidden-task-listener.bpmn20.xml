<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:camunda="http://camunda.org/schema/1.0/bpmn" targetNamespace="Examples">
  <process id="taskListenerSecurityProcess" isExecutable="true">
    <startEvent id="start" />
    <sequenceFlow id="flow1" sourceRef="start" targetRef="userTaskWithForbiddenTaskListener" />
    <userTask id="userTaskWithForbiddenTaskListener">
      <extensionElements>
        <camunda:taskListener event="create">
          <camunda:script scriptFormat="javascript">System.getenv('HOME');</camunda:script>
        </camunda:taskListener>
      </extensionElements>
    </userTask>
    <sequenceFlow id="flow2" sourceRef="userTaskWithForbiddenTaskListener" targetRef="end" />
    <endEvent id="end" />
  </process>
</definitions>
