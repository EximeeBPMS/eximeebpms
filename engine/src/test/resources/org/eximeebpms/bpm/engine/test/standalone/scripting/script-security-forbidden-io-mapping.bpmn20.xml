<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:camunda="http://camunda.org/schema/1.0/bpmn" targetNamespace="Examples">
  <process id="ioMappingSecurityProcess" isExecutable="true">
    <startEvent id="start" />
    <sequenceFlow id="flow1" sourceRef="start" targetRef="taskWithIoMapping" />
    <serviceTask id="taskWithIoMapping" camunda:class="java.lang.String">
      <extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="danger">
            <camunda:script scriptFormat="javascript">System.getenv('HOME');</camunda:script>
          </camunda:inputParameter>
        </camunda:inputOutput>
      </extensionElements>
    </serviceTask>
    <sequenceFlow id="flow2" sourceRef="taskWithIoMapping" targetRef="end" />
    <endEvent id="end" />
  </process>
</definitions>
