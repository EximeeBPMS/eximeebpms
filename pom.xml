    <profile>
      <!-- Scope of what gets published to Maven Central: consumable libraries, plus the two
        downloadable distributions eximeebpms-docker actually downloads from Central
        (eximeebpms-bpm-run, eximeebpms-bpm-tomcat - see distro/run and distro/tomcat below).
        Excludes qa, examples, distro/license-book, distro/jboss - none of those are things
        anyone consumes from Central, and staging them (plus javadoc/sources) pushed the
        JReleaser upload bundle past the ~2GB JVM array-size ceiling in Files.readAllBytes,
        which reliably OOM'd (see BPMS-385).

        distro/license-book and examples are still reachable below - not because anything
        downloads them from Central, but because kept modules have a real build-time
        dependency on one of their children (clients/java/client on eximeebpms-tomcat-assembly,
        itself needing distro/license-book; spring-boot-starter's own qa submodule, and
        distro/tomcat's and distro/run's own "distro" assemblies, on
        eximeebpms-example-invoice-jakarta). They carry their own sonatype-oss-release-scoped
        profile setting maven.deploy.skip=true, so they're built but never staged for Central.

        distro/tomcat and distro/run are listed by their aggregator path rather than their
        specific "distro" child for two reasons: (1) other profiles active alongside this one
        during "Release prepare"/"Release perform" (distro-tomcat, distro-run, ...) already
        reach the same child via a different module path, and listing a second, different path
        to the same child makes Maven reject it as a duplicate project; (2) do NOT add a
        same-named "sonatype-oss-release" profile to distro/tomcat/pom.xml or distro/run/pom.xml
        to scope this down further - activating any profile explicitly defined in a POM
        deactivates every OTHER activeByDefault profile in that SAME POM, which is exactly what
        silently dropped distro/tomcat/distro (eximeebpms-bpm-tomcat) and its webapp-jakarta
        dependency out of the 1.3.0 release despite this comment's predecessor's best intentions.
        Their own non-"distro" children (modules/rest, modules/oauth2, core, qa, ...) each carry
        their own maven.deploy.skip=true instead, so only eximeebpms-bpm-tomcat and
        eximeebpms-bpm-run actually get staged, verified locally at ~695MB (well within the 2GB
        ceiling) alongside the ~183MB from everything else already in this scope. -->
      <id>sonatype-oss-release</id>
      <modules>
        <module>spring-boot-starter</module>
        <module>quarkus-extension</module>
        <module>model-api</module>

        <module>engine</module>
        <module>engine-cdi</module>
        <module>engine-spring</module>
        <module>engine-rest</module>

        <module>engine-dmn</module>
        <module>connect</module>
        <module>juel</module>
        <module>spin</module>
        <module>commons</module>
        <module>freemarker-template-engine</module>

        <module>javaee/ejb-client</module>
        <module>javaee/ejb-client-jakarta</module>

        <module>webapps</module>

        <module>engine-plugins</module>

        <module>distro/sql-script</module>
        <module>distro/webjar</module>
        <!-- distro/tomcat and distro/run each publish only their own "distro" child (see
          comment above); everything else reachable through them is build-only. -->
        <module>distro/tomcat</module>
        <module>distro/run</module>
        <!-- built only, not deployed - see comment above -->
        <module>distro/license-book</module>
        <module>examples</module>

        <module>clients/java</module>

        <module>test-utils/junit5-extension</module>
        <module>test-utils/junit5-extension-dmn</module>
        <module>test-utils/assert</module>
        <module>test-utils/testcontainers</module>
        <module>test-utils/archunit</module>

        <module>internal-dependencies</module>
        <module>database</module>
        <module>parent</module>
        <module>bom</module>
      </modules>
    </profile>

    <profile>
      <!-- full profile is default and builds the complete distribution. Does not run integration tests. -->
      <id>full</id>
      <activation>
        <activeByDefault>true</activeByDefault>
      </activation>
      <modules>
        <module>spring-boot-starter</module>

        <module>quarkus-extension</module>

        <module>qa</module>

        <module>javaee/jobexecutor-ra</module>
        <module>javaee/jobexecutor-rar</module>

        <module>model-api</module>
        <module>engine-dmn</module>
        <module>connect</module>
        <module>juel</module>
        <module>spin</module>
        <module>commons</module>
        <module>freemarker-template-engine</module>

        <module>test-utils/testcontainers</module>
        <module>test-utils/junit5-extension</module>
        <module>test-utils/junit5-extension-dmn</module>
        <module>test-utils/assert</module>
        <module>test-utils/archunit</module>

        <module>engine</module>
        <module>engine-cdi</module>
        <module>engine-spring</module>
        <module>engine-rest</module>

        <module>webapps</module>

        <module>examples</module>

        <module>engine-plugins</module>

        <module>distro/license-book</module>
        <module>distro/jboss</module>
        <module>distro/tomcat</module>
        <module>distro/sql-script</module>
        <module>distro/run</module>
        <module>distro/webjar</module>

        <module>clients/java</module>

        <module>internal-dependencies</module>
        <module>database</module>
        <module>parent</module>
        <module>bom</module>
      </modules>
    </profile>

    <profile>
      <id>license-header-check</id>
      <build>
        <plugins>
          <plugin>
            <groupId>com.mycila</groupId>
            <artifactId>license-maven-plugin</artifactId>
          </plugin>
        </plugins>
      </build>
    </profile>
  </profiles>

